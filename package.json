{
  "name": "doccrea-syntax-highlighter",
  "version": "0.1.0",
  "private": true,
  "description": "Word Add-in die DocxTemplater-syntaxen kleurt en valideert. Gemaakt door MainFields.",
  "author": "MainFields (Jasper Bakker)",
  "homepage": "https://www.mainfields.nl",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jasper-MainFields/doccrea-syntax-highlighter"
  },
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/validate.ts",
    "start": "office-addin-debugging start manifest.xml desktop",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate-manifest": "office-addin-manifest validate manifest.xml",
    "generate-icons": "node scripts/generate-icons.mjs",
    "package:zip": "node scripts/build-sideload-zip.mjs"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.245",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "office-addin-debugging": "^6.0.7",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-manifest": "^2.1.3",
    "pngjs": "^7.0.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
